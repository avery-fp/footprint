{
  "name": "footprint-nano",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "fp:auto": "npx tsx src/fp/culture.mjs auto",
    "fp:batch": "npx tsx src/fp/culture.mjs batch",
    "fp:mint": "npx tsx src/fp/culture.mjs mint",
    "fp:darwin": "npx tsx src/fp/culture.mjs darwin",
    "fp:distribute": "npx tsx src/fp/culture.mjs distribute",
    "fp:ignite": "npx tsx src/fp/culture.mjs ignite",
    "aro": "npx tsx cli/aro.ts run",
    "aro:dry": "npx tsx cli/aro.ts run --dry",
    "aro:ingest": "npx tsx cli/aro.ts ingest-targets",
    "aro:events": "npx tsx cli/aro.ts ingest-events",
    "aro:export": "npx tsx cli/aro.ts export",
    "aro:list": "node scripts/list-engine.js",
    "aro:send": "node scripts/send-engine.js",
    "aro:send:dry": "node scripts/send-engine.js --dry-run",
    "launch": "node scripts/launch.js",
    "launch:dry": "node scripts/launch.js --dry-run",
    "scrape": "node scrape-engine.js",
    "send": "node send-engine.js",
    "typecheck": "tsc --noEmit",
    "screenshot:grid": "node scripts/screenshot-grid.js",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
