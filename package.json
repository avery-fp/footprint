    "archiver": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^3.0.6",
    "framer-motion": "^12.34.3",
    "jose": "^5.2.0",
    "nanoid": "^5.0.4",
    "next": "14.0.4",
    "pino": "^10.3.1",
    "qrcode": "^1.5.3",
    "react": "^18",
