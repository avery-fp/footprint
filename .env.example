# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──
NEXT_PUBLIC_APP_URL=https://footprint.onl
JWT_SECRET=your-secret-key-min-32-chars-long!

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ──
RESEND_API_KEY=re_...

# ── ARO (optional — distribution intelligence layer) ──
ARO_KEY=your-aro-key
ANTHROPIC_API_KEY=sk-ant-...
SCREENSHOT_API_KEY=your-screenshot-api-key

# ── Google (optional — ARO search) ──
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-custom-search-engine-id

# ── Twitter/X (optional — ARO distribution) ──
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ── Reddit (optional — ARO distribution) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── YouTube (optional — ARO distribution) ──
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_TOKEN=

# ── CLI / Pipeline ──
FP_BASE_URL=https://footprint.onl
