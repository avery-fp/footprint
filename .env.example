# ── Supabase ──
# REQUIRED: all three must be set. Supabase Dashboard → Settings → API.
# Missing ANON_KEY causes: auth session lookups fail (server log flood),
# browser client falls back to placeholder (broken RLS), upload.ts crashes.
# Codepaths: lib/supabase.ts, lib/supabase-auth-ssr.ts, lib/upload.ts,
#            app/api/auth/magic-link/route.ts
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──
NEXT_PUBLIC_APP_URL=https://www.footprint.onl
JWT_SECRET=your-secret-key-min-32-chars-long!

# ── OAuth (Supabase Auth providers) ──
# Configure Google & Apple OAuth in Supabase Dashboard → Authentication → Providers
# Google: https://supabase.com/docs/guides/auth/social-login/auth-google
# Apple:  https://supabase.com/docs/guides/auth/social-login/auth-apple

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend — fallback sender) ──
RESEND_API_KEY=re_...

# ── ARO Auth (scoped, headers-only) ──
ARO_KEY=your-aro-key                      # Machine scope: CLI tools (mint, ingest, packs, stats)
CRON_SECRET=your-cron-secret              # Cron scope: scheduled jobs (ignite, publish)
ARO_ADMIN_EMAILS=you@example.com          # Comma-separated admin allowlist for session auth

# ── ARO Intelligence ──
ANTHROPIC_API_KEY=sk-ant-...              # Claude API for Mirror Hook generation
SCREENSHOT_API_KEY=your-screenshot-api-key

# ── Email Swarm: Google Maps Scraper ──
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── Email Swarm: SES Multi-Region (up to 5 regions) ──
AWS_SES_REGION_1=us-east-1
AWS_SES_ACCESS_KEY_1=AKIA...
AWS_SES_SECRET_KEY_1=...
AWS_SES_FROM_1=hello@footprint.site
AWS_SES_DOMAIN_1=footprint.site

AWS_SES_REGION_2=us-west-2
AWS_SES_ACCESS_KEY_2=AKIA...
AWS_SES_SECRET_KEY_2=...
AWS_SES_FROM_2=hello@footprint.onl
AWS_SES_DOMAIN_2=footprint.onl

# ── Video Processing (Mux) ──
VIDEO_PROVIDER=mux
MUX_TOKEN_ID=...
MUX_TOKEN_SECRET=...
MUX_WEBHOOK_SECRET=...

# ── CLI / Pipeline ──
FP_BASE_URL=https://footprint.onl
