# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──
NEXT_PUBLIC_APP_URL=https://footprint.onl
JWT_SECRET=your-secret-key-min-32-chars-long!

# ── OAuth (Supabase Auth providers) ──
# Configure Google & Apple OAuth in Supabase Dashboard → Authentication → Providers
# Google: https://supabase.com/docs/guides/auth/social-login/auth-google
# Apple:  https://supabase.com/docs/guides/auth/social-login/auth-apple

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ──
RESEND_API_KEY=re_...

# ── ARO Auth (scoped, headers-only) ──
ARO_KEY=your-aro-key                      # Machine scope: CLI tools (mint, ingest, packs, stats)
CRON_SECRET=your-cron-secret              # Cron scope: scheduled jobs (ignite, publish)
ARO_ADMIN_EMAILS=you@example.com          # Comma-separated admin allowlist for session auth

# ── ARO Intelligence ──
ANTHROPIC_API_KEY=sk-ant-...
SCREENSHOT_API_KEY=your-screenshot-api-key

# ── ARO Reactor Safety (defaults are safe) ──
PUBLISH_MODE=dry_run                      # dry_run | live
PUBLISH_DAILY_CAP=50                      # Max posts per platform per day
ENABLED_PLATFORMS=reddit,twitter           # Comma-separated active platforms

# ── Google (optional — ARO search) ──
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-custom-search-engine-id

# ── Twitter/X (optional — ARO distribution) ──
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ── Reddit (optional — ARO distribution) ──
# Single-account (legacy):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Multi-account (browser-poster):
# REDDIT_ACCOUNT_1_USERNAME=your-username
# REDDIT_ACCOUNT_1_PASSWORD=your-password
# REDDIT_ACCOUNT_2_USERNAME=second-username
# REDDIT_ACCOUNT_2_PASSWORD=second-password
# ... up to REDDIT_ACCOUNT_N

# ── YouTube (optional — ARO distribution) ──
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_TOKEN=

# ── Outreach ──
APOLLO_API_KEY=                            # Apollo.io API key (list-engine.js contact sourcing)

# ── CLI / Pipeline ──
FP_BASE_URL=https://footprint.onl
